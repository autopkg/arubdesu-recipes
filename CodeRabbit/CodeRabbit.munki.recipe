<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Downloads the latest CodeRabbit CLI and imports it into Munki.</string>
	<key>Identifier</key>
	<string>com.github.autopkg.arubdesu-recipes.munki.coderabbit</string>
	<key>Input</key>
	<dict>
		<key>MUNKI_REPO_SUBDIR</key>
		<string></string>
		<key>NAME</key>
		<string>coderabbit</string>
		<key>pkginfo</key>
		<dict>
			<key>catalogs</key>
			<array>
				<string>testing</string>
			</array>
			<key>category</key>
			<string>Development</string>
			<key>description</key>
			<string>CodeRabbit is an AI-powered platform for code review, planning, and development workflows. Get AI code reviews directly in your CLI before you commit.

Installs the coderabbit binary to /usr/local/bin (already on PATH - unlike upstream's ~/.local/bin, no profile edits needed). Upstream's installer also creates a cr shortcut; this package does not. Add your own alias/symlink (e.g. ln -s /usr/local/bin/coderabbit /usr/local/bin/cr) if you want it.</string>
			<key>developer</key>
			<string>CodeRabbit, Inc.</string>
			<key>display_name</key>
			<string>CodeRabbit CLI</string>
			<key>name</key>
			<string>%NAME%</string>
			<key>unattended_install</key>
			<true/>
		</dict>
	</dict>
	<key>MinimumVersion</key>
	<string>1.0.0</string>
	<key>ParentRecipe</key>
	<string>com.github.autopkg.arubdesu-recipes.coderabbit.pkg</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>repo_subdirectory</key>
				<string>%MUNKI_REPO_SUBDIR%</string>
			</dict>
			<key>Processor</key>
			<string>MunkiImporter</string>
		</dict>
	</array>
</dict>
</plist>
