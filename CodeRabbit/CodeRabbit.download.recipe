<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Parses the latest version from cli.coderabbit.ai, downloads the
		matching darwin zip, unpacks it and verifies the code signature
		of the coderabbit binary.</string>
	<key>Identifier</key>
	<string>com.github.autopkg.arubdesu-recipes.coderabbit.download</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>coderabbit</string>
		<key>platform</key>
		<string>darwin-arm64</string>
		<key>Comment</key>
		<string>set to darwin-x64 for intel macs; the asset is coderabbit-%platform%.zip. coderabbit-linux-arm64.zip / coderabbit-linux-x64.zip (the -64 URLs) are also published if anyone wants to add linux-focused downstream recipes</string>
	</dict>
	<key>MinimumVersion</key>
	<string>1.0.0</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>https://cli.coderabbit.ai/releases/latest/VERSION</string>
				<key>re_pattern</key>
				<string>([\d.]+)</string>
				<key>result_output_var_name</key>
				<string>version</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLDownloader</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>https://cli.coderabbit.ai/releases/latest/coderabbit-%platform%.zip</string>
				<key>filename</key>
				<string>%NAME%-%version%.zip</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>EndOfCheckPhase</string>
		</dict>
		<dict>
			<key>Processor</key>
			<string>Unarchiver</string>
			<key>Arguments</key>
			<dict>
				<key>archive_path</key>
				<string>%pathname%</string>
				<key>destination_path</key>
				<string>%RECIPE_CACHE_DIR%/%NAME%</string>
				<key>purge_destination</key>
				<true/>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>CodeSignatureVerifier</string>
			<key>Arguments</key>
			<dict>
				<key>input_path</key>
				<string>%RECIPE_CACHE_DIR%/%NAME%/coderabbit</string>
				<key>requirement</key>
				<string>identifier "coderabbit" and anchor apple generic and certificate 1[field.1.2.840.113635.100.6.2.6] /* exists */ and certificate leaf[field.1.2.840.113635.100.6.1.13] /* exists */ and certificate leaf[subject.OU] = "47UZS55279"</string>
			</dict>
		</dict>
	</array>
</dict>
</plist>
