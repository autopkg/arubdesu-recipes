<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Downloads the latest ToolHive CLI and imports it into Munki.</string>
	<key>Identifier</key>
	<string>com.github.autopkg.arubdesu-recipes.munki.toolhive</string>
	<key>Input</key>
	<dict>
		<key>MUNKI_REPO_SUBDIR</key>
		<string></string>
		<key>NAME</key>
		<string>toolhive</string>
		<key>pkginfo</key>
		<dict>
			<key>catalogs</key>
			<array>
				<string>testing</string>
			</array>
			<key>category</key>
			<string>Development</string>
			<key>description</key>
			<string>ToolHive is an open-source manager for Model Context Protocol (MCP) servers. It runs MCP servers in isolated containers and exposes them to AI clients through a single CLI (thv), handling discovery, secrets, and secure configuration.

Installs the thv binary to /usr/local/bin (on PATH). ToolHive needs a running container runtime such as OrbStack or Docker to launch MCP servers. Note: if ToolHive Desktop is installed it manages its own CLI under ~/.toolhive/bin, which can conflict with this standalone binary.</string>
			<key>developer</key>
			<string>Stacklok, Inc.</string>
			<key>display_name</key>
			<string>ToolHive CLI</string>
			<key>name</key>
			<string>%NAME%</string>
			<key>unattended_install</key>
			<true/>
		</dict>
	</dict>
	<key>MinimumVersion</key>
	<string>1.0.0</string>
	<key>ParentRecipe</key>
	<string>com.github.autopkg.arubdesu-recipes.toolhive.pkg</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>repo_subdirectory</key>
				<string>%MUNKI_REPO_SUBDIR%</string>
			</dict>
			<key>Processor</key>
			<string>MunkiImporter</string>
		</dict>
	</array>
</dict>
</plist>
